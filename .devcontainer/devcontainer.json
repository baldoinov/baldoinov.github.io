{
    "name": "baldoinov",
    "dockerFile": "Dockerfile",
    "forwardPorts": [4000, 35729],
    "context": "..",
    "customizations": {
        "codespaces": {
            "repositories": {
            "baldoinov/private-drafts": { "permissions": { "contents": "write" } }
            }
        }
    },
    "postStartCommand": "git clone https://github.com/baldoinov/private-drafts.git _drafts || true"
}